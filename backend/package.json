{
  "name": "signal-theory-backend",
  "version": "1.0.0",
  "description": "Signal Theory API server",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs'),path=require('path');const src=path.join(__dirname,'email-action-plans');const dest=path.join(__dirname,'dist','email-action-plans');fs.mkdirSync(dest,{recursive:true});fs.readdirSync(src).forEach(f=>fs.copyFileSync(path.join(src,f),path.join(dest,f)))\"",
    "start": "node -e \"require('./dist/db/migrate')\" && node load-templates.js && node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "migrate": "node -e \"require('./dist/db/migrate')\"",
    "migrate:dev": "ts-node src/db/migrate.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "jsonwebtoken": "^9.0.2",
    "openai": "^6.33.0",
    "pg": "^8.12.0",
    "stripe": "^16.12.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.10",
    "@types/pg": "^8.11.6",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.3"
  }
}
