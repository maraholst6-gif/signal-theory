# Database
DATABASE_URL=postgresql://user:password@localhost:5432/signal_theory

# Auth
JWT_SECRET=your-random-secret-min-32-chars
JWT_REFRESH_SECRET=your-random-refresh-secret-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# OpenAI
OPENAI_API_KEY=sk-...

# RevenueCat
REVENUECAT_WEBHOOK_SECRET=your-revenuecat-webhook-secret

# Microsoft Graph (email sending — see docs/AZURE-SETUP.md)
MICROSOFT_TENANT_ID=your-azure-tenant-id
MICROSOFT_CLIENT_ID=your-azure-client-id
MICROSOFT_CLIENT_SECRET=your-azure-client-secret
EMAIL_FROM=you@yourdomain.com
APP_BASE_URL=https://signaltheory.app

# Server
PORT=3000
NODE_ENV=development
